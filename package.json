{
  "name": "config-converter",
  "version": "1.4.1",
  "private": true,
  "description": "Convert between YAML, JSON, and TOML formats instantly. All client-side, privacy-first.",
  "keywords": [
    "yaml",
    "json",
    "toml",
    "converter",
    "config",
    "configuration",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsJust-tools/config-converter.git"
  },
  "homepage": "https://itsjust.tools/config-converter",
  "bugs": {
    "url": "https://github.com/itsjust-tools/config-converter/issues"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run build -w @itsjust/core && next build",
    "start": "next start",
    "lint": "mkdir -p test-results && eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --ui",
    "test:ui": "vitest --ui",
    "prepare": "husky install || true",
    "deps:check": "depcheck",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@itsjust/core": "*",
    "html-to-image": "^1.11.13",
    "js-yaml": "^4.2.0",
    "lz-string": "^1.5.0",
    "next": "^16.2.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "smol-toml": "^1.6.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0",
    "yarn": ">=1.22.0"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css,mdx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "depcheck": "^1.4.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^6",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@emnapi/runtime": "^1.10.0"
  }
}
